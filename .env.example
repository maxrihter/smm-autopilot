# ── Scraping ───────────────────────────────────────────────
APIFY_TOKEN=                       # required for live runs; NOT needed for `make demo`
INSTAGRAM_COOKIES=                 # optional — warmed-account session; wire into the Apify actor input for gated content (see docs/SETUP.md). Never commit real values.

# ── LLM providers (router — see the `llm:` block in tenant.yaml) ───────────
# Only set keys for providers your tenant's `llm:` block actually uses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                    # OpenAI-compatible: OpenAI, local Ollama, or imago.market
OPENAI_BASE_URL=
MISTRAL_API_KEY=                   # optional — pip install "smm-autopilot[mistral]"
GOOGLE_API_KEY=                    # optional — pip install "smm-autopilot[google]"

# ── Storage ────────────────────────────────────────────────
# DATABASE_URL=                    # storage defaults to local SQLite (./data/state.db); Postgres = optional extra, not auto-wired

# ── Optional output adapters ───────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=INFO
